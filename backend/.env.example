# Postgres connection string from Render (or leave blank for local SQLite)
DATABASE_URL=sqlite:///./sentinel.db

# Your Groq API key from console.groq.com
GROQ_API_KEY=your_key_here

# Render sets this automatically, only needed for local override
PORT=8000

# Comma-separated list of allowed frontend origins (your Vercel URL)
CORS_ORIGINS=http://localhost:3000
